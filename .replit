modules = ["web", "nodejs-20", "nix", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5055
externalPort = 3000

[[ports]]
localPort = 5056
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000
